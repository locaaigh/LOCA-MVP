# ─────────────────────────────────────────────────────────────
# LOCA MVP — variables de entorno (todas OPCIONALES)
# La app funciona en MODO DEMO sin ninguna de estas variables.
# ─────────────────────────────────────────────────────────────

# Proveedor de texto: anthropic | openai (default: anthropic si hay key, sino openai)
AI_TEXT_PROVIDER=anthropic

# Anthropic (Claude) — recomendado para textos
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI — textos (si AI_TEXT_PROVIDER=openai) e imágenes
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
