# ─────────────────────────────────────────────────────────────
# LOCA MVP — variables de entorno (todas OPCIONALES)
# La app funciona en MODO DEMO sin ninguna de estas variables.
# ─────────────────────────────────────────────────────────────

# Proveedor de texto: anthropic | openai (default: anthropic si hay key, sino openai)
AI_TEXT_PROVIDER=anthropic

# Proveedor de imágenes: gemini | openai (default: gemini si hay key, sino openai)
AI_IMAGE_PROVIDER=gemini

# Google Gemini — imágenes (Nano Banana)
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Anthropic (Claude) — recomendado para textos
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI — textos (si AI_TEXT_PROVIDER=openai) e imágenes
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# ─────────────────────────────────────────────────────────────
# Supabase — auth + persistencia + storage de imágenes
# Sin estas variables la app funciona igual pero solo en modo
# demo local (datos en el navegador, sin cuentas reales).
# Copiá los valores de Settings → API en tu proyecto Supabase.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secreta: solo la usa el servidor. NUNCA exponer al frontend.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# Meta (Instagram/Facebook) — OAuth y publicación
# Credenciales de la app en developers.facebook.com.
# Sin estas variables la conexión con Meta queda deshabilitada.
# ─────────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
# Opcional: si no está, se deriva del origin del request.
# Debe estar registrada como "Valid OAuth Redirect URI" en Meta Console.
META_OAUTH_REDIRECT_URI=
# Clave de 32 bytes en base64 para cifrar tokens (openssl rand -base64 32)
META_TOKEN_ENCRYPTION_KEY=
# Opcional: pisar los scopes del OAuth (separados por coma) si la app de
# Meta todavía no tiene habilitados los permisos de Instagram.
# META_SCOPES=pages_show_list,pages_read_engagement,pages_manage_posts
# Protege el cron de refresh de tokens (Vercel lo manda como Bearer token).
# Generá uno con: openssl rand -hex 32
CRON_SECRET=
