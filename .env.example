# ─────────────────────────────────────────────────────────────
# LOCA MVP — variables de entorno (todas OPCIONALES)
# La app funciona en MODO DEMO sin ninguna de estas variables.
# ─────────────────────────────────────────────────────────────

# Activa generación REAL de texto e imágenes con OpenAI.
# Si no está, LOCA usa contenidos mock inteligentes y placeholders.
OPENAI_API_KEY=

# Modelo de texto (opcional). Default: gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini

# Modelo de imágenes (opcional). Default: gpt-image-1
# Alternativa válida: dall-e-3
OPENAI_IMAGE_MODEL=gpt-image-1
