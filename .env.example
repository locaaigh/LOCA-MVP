# ─────────────────────────────────────────────────────────────
# LOCA MVP — variables de entorno (todas OPCIONALES)
# La app funciona en MODO DEMO sin ninguna de estas variables.
# ─────────────────────────────────────────────────────────────

# Proveedor de texto: anthropic | openai (default: anthropic si hay key, sino openai)
AI_TEXT_PROVIDER=anthropic

# Proveedor de imágenes: gemini | openai (default: gemini si hay key, sino openai)
AI_IMAGE_PROVIDER=gemini

# Google Gemini — imágenes (Nano Banana)
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Anthropic (Claude) — recomendado para textos
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI — textos (si AI_TEXT_PROVIDER=openai) e imágenes
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# ─────────────────────────────────────────────────────────────
# Supabase — auth + persistencia + storage de imágenes
# Sin estas variables la app funciona igual pero solo en modo
# demo local (datos en el navegador, sin cuentas reales).
# Copiá los valores de Settings → API en tu proyecto Supabase.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secreta: solo la usa el servidor. NUNCA exponer al frontend.
SUPABASE_SERVICE_ROLE_KEY=
